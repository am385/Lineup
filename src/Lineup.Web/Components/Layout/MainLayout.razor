@inherits LayoutComponentBase

<div class="page">
    <div class="sidebar">
        <NavMenu />
    </div>

    <main>
        <div class="top-row px-4">
            <div class="d-flex align-items-center gap-3">
                <div class="dropdown">
                    <button class="btn btn-sm btn-outline-secondary dropdown-toggle" type="button"
                            data-bs-toggle="dropdown" aria-expanded="false" title="Toggle theme"
                            id="theme-toggle-btn">
                        <span id="theme-icon" class="bi bi-sun-fill"></span>
                    </button>
                    <ul class="dropdown-menu dropdown-menu-end">
                        <li>
                            <button class="dropdown-item" id="theme-opt-light" onclick="setThemeFromUI('light')">
                                <span class="bi bi-sun-fill me-2"></span>Light
                            </button>
                        </li>
                        <li>
                            <button class="dropdown-item" id="theme-opt-dark" onclick="setThemeFromUI('dark')">
                                <span class="bi bi-moon-stars-fill me-2"></span>Dark
                            </button>
                        </li>
                        <li>
                            <button class="dropdown-item" id="theme-opt-auto" onclick="setThemeFromUI('auto')">
                                <span class="bi bi-circle-half me-2"></span>Auto
                            </button>
                        </li>
                    </ul>
                </div>
            </div>
        </div>

        <article class="content px-4">
            @Body
        </article>
    </main>
</div>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>
