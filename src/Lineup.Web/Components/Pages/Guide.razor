@page "/guide"
@using Lineup.HDHomeRun.Api.Models
@rendermode InteractiveServer

<PageTitle>Guide</PageTitle>

<h1><span class="bi bi-grid-3x3 me-2"></span>Guide</h1>

<div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
    <div class="btn-group" role="group">
        <button class="btn btn-outline-primary @(_selectedDate == DateTime.Today ? "active" : "")" 
                @onclick="() => SelectDate(Tz.Today)">
            Today
        </button>
        <button class="btn btn-outline-primary @(_selectedDate == Tz.Today.AddDays(1) ? "active" : "")" 
                @onclick="() => SelectDate(Tz.Today.AddDays(1))">
            Tomorrow
        </button>
        @for (int i = 2; i <= 6; i++)
        {
            var date = Tz.Today.AddDays(i);
            <button class="btn btn-outline-primary @(_selectedDate == date ? "active" : "")" 
                    @onclick="() => SelectDate(date)">
                @date.ToString("ddd")
            </button>
        }
    </div>
    
    <div class="d-flex gap-2">
        <button class="btn btn-outline-primary" @onclick="JumpToNow" 
                disabled="@(_selectedDate == Tz.Today && IsShowingCurrentTime())">
            <span class="bi bi-clock me-1"></span>Now
        </button>
        <div class="btn-group" role="group">
            <button class="btn btn-outline-secondary" 
                    @onclick="PreviousTimeBlock" disabled="@(_startHour <= 0)">
                <span class="bi bi-chevron-left"></span>
            </button>
            <span class="btn btn-outline-secondary disabled">
                @FormatTimeRange()
            </span>
            <button class="btn btn-outline-secondary" 
                    @onclick="NextTimeBlock" disabled="@(_startHour + _hoursToShow >= 24)">
                <span class="bi bi-chevron-right"></span>
            </button>
        </div>
    </div>
</div>

@if (_isLoading)
{
    <div class="text-center py-5">
        <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">Loading...</span>
        </div>
        <p class="text-muted mt-2">Loading guide data...</p>
    </div>
}
else if (_channels.Count == 0)
{
    <div class="alert alert-info">
        <span class="bi bi-info-circle me-2"></span>
        No EPG data available. Please fetch EPG data from the Dashboard first.
    </div>
}
else
{
    <div class="guide-container" @ref="_guideContainer">
        <!-- Time header -->
        <div class="guide-header">
            <div class="guide-channel-header">Channel</div>
            <div class="guide-time-slots" style="width: @(_programsWidth)px;">
                @foreach (var slot in _timeSlots)
                {
                    <div class="guide-time-slot" style="width: @(SlotWidthPx)px;">
                        @slot.ToString("h:mm tt")
                    </div>
                }
            </div>
        </div>
        
        <!-- Channel rows -->
        @foreach (var channel in _channels)
        {
            <div class="guide-row">
                <div class="guide-channel">
                    <div class="channel-number">@channel.GuideNumber</div>
                    <div class="channel-name" title="@channel.GuideName">@TruncateText(channel.GuideName, 12)</div>
                </div>
                <div class="guide-programs" style="width: @(_programsWidth)px;">
                    @{
                        var channelPrograms = GetProgramsForChannel(channel.GuideNumber);
                    }
                    @foreach (var program in channelPrograms)
                    {
                        var (style, widthPx) = GetProgramLayout(program);
                        var isCurrentlyAiring = IsCurrentlyAiring(program);
                        <div class="guide-program @(isCurrentlyAiring ? "currently-airing" : "")" 
                             style="@style"
                             title="@GetProgramTooltip(program)"
                             @onclick="() => ShowProgramDetails(program)">
                            <div class="program-title">@TruncateText(program.Title, EstimateMaxChars(widthPx, 7))</div>
                            @if (!string.IsNullOrEmpty(program.EpisodeTitle))
                            {
                                <div class="program-episode">@TruncateText(program.EpisodeTitle, EstimateMaxChars(widthPx, 6))</div>
                            }
                        </div>
                    }
                </div>
            </div>
        }
    </div>
}

<!-- Program Details Modal -->
@if (_selectedProgram != null)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);" @onclick="CloseModal">
        <div class="modal-dialog modal-lg" @onclick:stopPropagation="true">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">@_selectedProgram.Title</h5>
                    <button type="button" class="btn-close" @onclick="CloseModal"></button>
                </div>
                <div class="modal-body">
                    <div class="row">
                        <div class="col-md-8">
                            @if (!string.IsNullOrEmpty(_selectedProgram.EpisodeTitle))
                            {
                                <h6 class="text-muted">@_selectedProgram.EpisodeTitle</h6>
                            }
                            @if (!string.IsNullOrEmpty(_selectedProgram.Synopsis))
                            {
                                <p>@_selectedProgram.Synopsis</p>
                            }
                            else
                            {
                                <p class="text-muted">No description available.</p>
                            }
                        </div>
                        <div class="col-md-4">
                            <table class="table table-sm">
                                <tbody>
                                    <tr>
                                        <td class="fw-bold">Channel:</td>
                                        <td>@_selectedProgram.GuideNumber</td>
                                    </tr>
                                    <tr>
                                        <td class="fw-bold">Start:</td>
                                        <td>@FormatProgramTime(_selectedProgram.StartTime)</td>
                                    </tr>
                                    <tr>
                                        <td class="fw-bold">End:</td>
                                        <td>@FormatProgramTime(_selectedProgram.EndTime)</td>
                                    </tr>
                                    <tr>
                                        <td class="fw-bold">Duration:</td>
                                        <td>@GetDuration(_selectedProgram) min</td>
                                    </tr>
                                    @if (!string.IsNullOrEmpty(_selectedProgram.EpisodeNumber))
                                    {
                                        <tr>
                                            <td class="fw-bold">Episode:</td>
                                            <td>@_selectedProgram.EpisodeNumber</td>
                                        </tr>
                                    }
                                    @if (_selectedProgram.OriginalAirdate.HasValue)
                                    {
                                        <tr>
                                            <td class="fw-bold">Original Air:</td>
                                            <td>@FormatOriginalAirdate(_selectedProgram.OriginalAirdate.Value)</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                            @if (_selectedProgram.Filter?.Any() == true)
                            {
                                <div class="mt-2">
                                    @foreach (var category in _selectedProgram.Filter.Take(3))
                                    {
                                        <span class="badge bg-secondary me-1">@category</span>
                                    }
                                </div>
                            }
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="CloseModal">Close</button>
                </div>
            </div>
        </div>
    </div>
}

<style>
    /* Guide color tokens - light mode defaults */
    .guide-container {
        --guide-border: #dee2e6;
        --guide-header-bg: #f8f9fa;
        --guide-row-hover: #f8f9fa;
        --guide-channel-number: #0d6efd;
        --guide-channel-name: #6c757d;
        --guide-program-bg: #e7f1ff;
        --guide-program-border: #b6d4fe;
        --guide-program-hover-bg: #cfe2ff;
        --guide-program-hover-shadow: rgba(0,0,0,0.15);
        --guide-program-airing-bg: #d1e7dd;
        --guide-program-airing-border: #a3cfbb;
        --guide-program-airing-hover-bg: #badbcc;
        --guide-episode-color: #6c757d;
    }

    /* Dark mode overrides */
    [data-bs-theme="dark"] .guide-container {
        --guide-border: #3a3f44;
        --guide-header-bg: #1e2125;
        --guide-row-hover: #2b3035;
        --guide-channel-number: #6cb4f0;
        --guide-channel-name: #9ea7b0;
        --guide-program-bg: #1a2d47;
        --guide-program-border: #2b5a94;
        --guide-program-hover-bg: #213a5c;
        --guide-program-hover-shadow: rgba(0,0,0,0.4);
        --guide-program-airing-bg: #1a3a2a;
        --guide-program-airing-border: #2d7a52;
        --guide-program-airing-hover-bg: #224a36;
        --guide-episode-color: #9ea7b0;
    }

    .guide-container {
        border: 1px solid var(--guide-border);
        border-radius: 0.375rem;
        overflow-x: auto;
        overflow-y: hidden;
        max-width: 100%;
    }
    
    .guide-header {
        display: flex;
        background-color: var(--guide-header-bg);
        border-bottom: 2px solid var(--guide-border);
        position: sticky;
        top: 0;
        z-index: 10;
        width: fit-content;
        min-width: 100%;
    }
    
    
    .guide-channel-header {
        min-width: 100px;
        width: 100px;
        padding: 0.75rem 0.5rem;
        font-weight: bold;
        border-right: 1px solid var(--guide-border);
        flex-shrink: 0;
    }
    
    .guide-time-slots {
        display: flex;
        overflow: hidden;
    }
    
    .guide-time-slot {
        padding: 0.75rem 0.25rem;
        text-align: center;
        font-weight: 500;
        font-size: 0.85rem;
        border-right: 1px solid var(--guide-border);
        flex-shrink: 0;
    }
    
    .guide-row {
        display: flex;
        border-bottom: 1px solid var(--guide-border);
        width: fit-content;
        min-width: 100%;
    }
    
    .guide-row:hover {
        background-color: var(--guide-row-hover);
    }
    
    .guide-channel {
        min-width: 100px;
        width: 100px;
        padding: 0.35rem 0.5rem;
        border-right: 1px solid var(--guide-border);
        display: flex;
        flex-direction: column;
        justify-content: center;
        flex-shrink: 0;
    }
    
    .channel-number {
        font-weight: bold;
        font-size: 0.9rem;
        color: var(--guide-channel-number);
    }
    
    .channel-name {
        font-size: 0.75rem;
        color: var(--guide-channel-name);
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }
    
    .guide-programs {
        position: relative;
        min-height: 50px;
        overflow: hidden;
    }
    
    .guide-program {
        position: absolute;
        top: 2px;
        bottom: 2px;
        background-color: var(--guide-program-bg);
        border: 1px solid var(--guide-program-border);
        border-radius: 0.25rem;
        padding: 0.2rem 0.4rem;
        overflow: hidden;
        cursor: pointer;
        transition: all 0.15s;
        color: var(--bs-body-color);
    }
    
    .guide-program:hover {
        background-color: var(--guide-program-hover-bg);
        z-index: 5;
        box-shadow: 0 2px 8px var(--guide-program-hover-shadow);
    }
    
    .guide-program.currently-airing {
        background-color: var(--guide-program-airing-bg);
        border-color: var(--guide-program-airing-border);
    }
    
    .guide-program.currently-airing:hover {
        background-color: var(--guide-program-airing-hover-bg);
    }
    
    .program-title {
        font-weight: 500;
        font-size: 0.8rem;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }
    
    .program-episode {
        font-size: 0.7rem;
        color: var(--guide-episode-color);
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }
    
    @@media (max-width: 768px) {
        .guide-channel-header,
        .guide-channel {
            min-width: 70px;
            width: 70px;
        }
        
        .channel-name {
            display: none;
        }
    }
</style>

